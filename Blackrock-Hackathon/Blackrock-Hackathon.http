  ]
}


### Temporal Constraints Validator
POST {{BlackRock_Hackathon_HostAddress}}/blackrock/challenge/v1/transactions/filter
Accept: application/json
Content-Type: application/json

{
  "q": [
    {
      "fixed": 0,
      "start": "2023-07-01T00:00:00",
      "end": "2023-07-31T23:59:59"
    }
  ],
  "p": [
    {
      "extra": 30,
      "start": "2023-10-01T00:00:00",
      "end": "2023-12-31T23:59:59"
    }
  ],
  "k": [
    {
      "start": "2023-01-01T00:00:00",
      "end": "2023-12-31T23:59:59"
    }
  ],
  "wage": 50000,
  "transactions": [
    {
      "date": "2023-02-28T15:49:20",
      "amount": 375
    },
    {
      "date": "2023-07-15T10:30:00",
      "amount": 620
    },
    {
      "date": "2023-10-12T20:15:30",
      "amount": 250
    },
    {
      "date": "2023-10-12T20:15:30",
      "amount": 250
    },
    {
      "date": "2023-12-17T08:09:45",
      "amount": -480
    }
  ]
}

